* text=auto eol=lf

# Text files (explicit, so they're never mishandled regardless of git config)
*.lib       text eol=lf
*.inc       text eol=lf
*.cir       text eol=lf
*.sym       text eol=lf
*.py        text eol=lf
*.md        text eol=lf
*.csv       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
.gitattributes text eol=lf
.gitignore  text eol=lf

# Binary blobs (never normalize)
*.docx      binary
*.pdf       binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary

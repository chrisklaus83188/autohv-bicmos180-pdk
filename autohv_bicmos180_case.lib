.param W_REF=10u
.param mtot={(W/W_REF)*M}
.param DVTH_MM={MM_ON*AGAUSS(0, 0.03, 3)/sqrt(max(mtot,1e-6))}
ESHIFT g_int s value={V(g,s)+DVTH_MM}
M0 d g_int s NDMOS120_INT m={mtot}
.ends NDMOS120
.subckt NDMOS40 d g s params: W=10u M=1
* HV DMOS: width W is the size knob (m=W/W_REF); channel/drift length fixed at process min
.param W_REF=10u
.param mtot={(W/W_REF)*M}
.param DVTH_MM={MM_ON*AGAUSS(0, 0.0085, 3)/sqrt(max(mtot,1e-6))}
ESHIFT g_int s value={V(g,s)+DVTH_MM}
M0 d g_int s NDMOS40_INT m={mtot}
.ends NDMOS40
.subckt PDMOS40 d g s params: W=10u M=1
* HV DMOS: width W is the size knob (m=W/W_REF); channel/drift length fixed at process min
.param W_REF=10u
.param mtot={(W/W_REF)*M}
.param DVTH_MM={MM_ON*AGAUSS(0, 0.0085, 3)/sqrt(max(mtot,1e-6))}
ESHIFT g_int s value={V(g,s)+DVTH_MM}
M0 d g_int s PDMOS40_INT m={mtot}
.ends PDMOS40
.subckt NDMOS80 d g s params: W=10u M=1
* HV DMOS: width W is the size knob (m=W/W_REF); channel/drift length fixed at process min
.param W_REF=10u
.param mtot={(W/W_REF)*M}
.param DVTH_MM={MM_ON*AGAUSS(0, 0.0095, 3)/sqrt(max(mtot,1e-6))}
ESHIFT g_int s value={V(g,s)+DVTH_MM}
M0 d g_int s NDMOS80_INT m={mtot}
.ends NDMOS80
.subckt PDMOS80 d g s params: W=10u M=1
* HV DMOS: width W is the size knob (m=W/W_REF); channel/drift length fixed at process min
.param W_REF=10u
.param mtot={(W/W_REF)*M}
.param DVTH_MM={MM_ON*AGAUSS(0, 0.0095, 3)/sqrt(max(mtot,1e-6))}
ESHIFT g_int s value={V(g,s)+DVTH_MM}
M0 d g_int s PDMOS80_INT m={mtot}
.ends PDMOS80
.subckt NDMOS200 d g s params: W=10u L=8u M=1
* 200V LDMOS: W free (m=W/W_REF); L = drift length. Recommended RESURF window ~5u..16u.
* L raises drift Rdson (~linear); breakdown is held at the model rating (see notes).
.param W_REF=10u
.param L_REF=8u
.param L_MIN=5u
.param Leff={max(L,L_MIN)}
.param mtot={(W/W_REF)*M}
.param DVTH_MM={MM_ON*AGAUSS(0, 0.011, 3)/sqrt(max(mtot,1e-6))}
.param RDRIFT={max(1.2*(Leff/L_REF-1)/mtot, 1e-6)}
ESHIFT g_int s value={V(g,s)+DVTH_MM}
Rdrift d dd {RDRIFT}
M0 dd g_int s NDMOS200_INT m={mtot}
.ends NDMOS200
.subckt DNMOS20 d g s params: W=10u M=1
* HV DMOS: width W is the size knob (m=W/W_REF); channel/drift length fixed at process min
.param W_REF=10u
.param mtot={(W/W_REF)*M}
.param DVTH_MM={MM_ON*AGAUSS(0, 0.024, 3)/sqrt(max(mtot,1e-6))}
ESHIFT g_int s value={V(g,s)+DVTH_MM}
M0 d g_int s DNMOS20_INT m={mtot}
.ends DNMOS20
.subckt NPN_LV c b e params: AREA=1
.param AREAEFF={AREA*(1+MM_ON*AGAUSS(0, 0.012/sqrt(AREA+1e-12), 3))}
Q0 c b e NPN_LV_INT area={AREAEFF}
.ends NPN_LV


.subckt NDMOS200 d g s params: W=10u L=8u M=1
* 200V LDMOS: W free (m=W/W_REF); L = drift length. Recommended RESURF window ~5u..16u.
* L raises drift Rdson (~linear); breakdown is held at the model rating (see notes).
.param W_REF=10u
.param L_REF=8u
.param L_MIN=5u
.param Leff={max(L,L_MIN)}
.param mtot={(W/W_REF)*M}
.param DVTH_MM={MM_ON*AGAUSS(0, 0.011, 3)/sqrt(max(mtot,1e-6))}
.param RDRIFT={max(1.2*(Leff/L_REF-1)/mtot, 1e-6)}
.param Rth=80        ; K/W: thermal R, default for 200V class (override per-instance)
.param Cth=5e-06     ; J/K: thermal capacitance
Vshift g g_int DC {-DVTH_MM}
Rgmin  g g_int 1e9   ; gmin shunt: breaks the singular matrix when MM_ON=0 (DVTH_MM=0V) for cascoded LDMOS
Rdrift d dd {RDRIFT}
.if (SH_ON==1)
* Self-heating ON (item #3): Vth shift + Pdiss-to-TJ thermal network.
B_thvth g_int g_th V={TC_VTO_NDMOS200*V(TJ)}
Vsense dd dd_sense DC 0
M0 dd_sense g_th s NDMOS200_INT m={mtot}
B_pdiss 0 TJ I={V(d,s)*i(Vsense)}
Rth_n TJ 0 {Rth}
Cth_n TJ 0 {Cth} IC=0
.else
* Self-heating OFF (default): original M0 path, no thermal elements added.
M0 dd g_int s NDMOS200_INT m={mtot}
.endif
.ends NDMOS200
.subckt PDMOS200 d g s params: W=10u L=8u M=1
* 200V LDMOS p-channel: W free (m=W/W_REF); L = drift length. Recommended RESURF window ~5u..16u.
* L raises drift Rdson (~linear); breakdown is held at the model rating. RDRIFT scale factor
* is 3.0 (vs 1.2 on NDMOS200): PMOS drift in n-well has ~2.5x higher per-um R, so the per-um
* delta-R also scales by ~2.5x.
.param W_REF=10u
.param L_REF=8u
.param L_MIN=5u
.param Leff={max(L,L_MIN)}
.param mtot={(W/W_REF)*M}
.param DVTH_MM={MM_ON*AGAUSS(0, 0.011, 3)/sqrt(max(mtot,1e-6))}
.param RDRIFT={max(3.0*(Leff/L_REF-1)/mtot, 1e-6)}
.param Rth=80        ; K/W: thermal R, default for 200V class (override per-instance)
.param Cth=5e-06     ; J/K: thermal capacitance
Vshift g g_int DC {-DVTH_MM}
Rgmin  g g_int 1e9   ; gmin shunt: breaks the singular matrix when MM_ON=0 (DVTH_MM=0V) for cascoded LDMOS
Rdrift d dd {RDRIFT}
.if (SH_ON==1)
* Self-heating ON (item #3): Vth shift + Pdiss-to-TJ thermal network.
B_thvth g_int g_th V={TC_VTO_PDMOS200*V(TJ)}
Vsense dd dd_sense DC 0
M0 dd_sense g_th s PDMOS200_INT m={mtot}
B_pdiss 0 TJ I={V(d,s)*i(Vsense)}
Rth_n TJ 0 {Rth}
Cth_n TJ 0 {Cth} IC=0
.else
* Self-heating OFF (default): original M0 path, no thermal elements added.
M0 dd g_int s PDMOS200_INT m={mtot}
.endif
.ends PDMOS200
.subckt DNMOS20 d g s params: W=10u M=1
* HV DMOS: width W is the size knob (m=W/W_REF); channel/drift length fixed at process min
.param W_REF=10u

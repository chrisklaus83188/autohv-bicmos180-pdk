.subckt NDMOS20 d g s params: W=10u M=1
* HV DMOS: width W is the size knob (m=W/W_REF); channel/drift length fixed at process min
.param W_REF=10u
.param mtot={(W/W_REF)*M}
.param DVTH_MM={MM_ON*AGAUSS(0, 0.024, 3)/sqrt(max(mtot,1e-6))}
ESHIFT g_int s value={V(g,s)+DVTH_MM}
M0 d g_int s NDMOS20_INT m={mtot}
.ends NDMOS20
.subckt PDMOS20 d g s params: W=10u M=1
* HV DMOS: width W is the size knob (m=W/W_REF); channel/drift length fixed at process min
.param W_REF=10u
.param mtot={(W/W_REF)*M}
.param DVTH_MM={MM_ON*AGAUSS(0, 0.024, 3)/sqrt(max(mtot,1e-6))}
ESHIFT g_int s value={V(g,s)+DVTH_MM}
M0 d g_int s PDMOS20_INT m={mtot}
.ends PDMOS20
.subckt NDMOS60 d g s params: W=10u M=1
* HV DMOS: width W is the size knob (m=W/W_REF); channel/drift length fixed at process min
.param W_REF=10u
.param mtot={(W/W_REF)*M}
.param DVTH_MM={MM_ON*AGAUSS(0, 0.027, 3)/sqrt(max(mtot,1e-6))}
ESHIFT g_int s value={V(g,s)+DVTH_MM}
M0 d g_int s NDMOS60_INT m={mtot}
.ends NDMOS60
.subckt PDMOS60 d g s params: W=10u M=1
* HV DMOS: width W is the size knob (m=W/W_REF); channel/drift length fixed at process min
.param W_REF=10u
.param mtot={(W/W_REF)*M}
.param DVTH_MM={MM_ON*AGAUSS(0, 0.027, 3)/sqrt(max(mtot,1e-6))}
ESHIFT g_int s value={V(g,s)+DVTH_MM}
M0 d g_int s PDMOS60_INT m={mtot}
.ends PDMOS60

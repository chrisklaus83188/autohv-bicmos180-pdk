* ============================================================================
* AutoHV_BiCMOS180 - device subcircuit library for Qucs-S (case-parameterized).
* Drop this file + autohv_bicmos180_case_models.inc + the autohv_bicmos180_case/
* symbol folder into a Qucs-S library directory (e.g. ~/.qucs/user_lib or
* <install>/share/qucs-s/library). All 38 .SUBCKT devices then appear in the
* left-side Library dock with their symbols, drag-and-drop ready.
* Corner: set the global 'case' param (0=TT 1=FF 2=SS 3=FS 4=SF); see the .inc.
* ============================================================================
.include "autohv_bicmos180_case_models.inc"

* ============================ DEVICE SUBCIRCUITS ============================
* Place these via the Qucs-S 'SPICE Library Device' (File Components group).
.subckt NMOS18 d g s b params: W=10u L=1u M=1
.param AUM2={(W/1u)*(L/1u)}
.param DVTH_MM={MM_ON*AGAUSS(0, 0.0105/sqrt(AUM2+1e-12), 3)}
.param DWREL_MM={MM_ON*AGAUSS(0, 0.0075/sqrt(AUM2+1e-12), 3)}
.param DLREL_MM={MM_ON*AGAUSS(0, 0.0045000000000000005/sqrt(AUM2+1e-12), 3)}
.param WEFF={W*(1+DWREL_MM)}
.param LEFF={L*(1+DLREL_MM)}
M0 d g s b NMOS18_INT W={WEFF} L={LEFF} M={M} delvto={DVTH_MM}
.ends NMOS18

.subckt PMOS18 d g s b params: W=10u L=1u M=1
.param AUM2={(W/1u)*(L/1u)}
.param DVTH_MM={MM_ON*AGAUSS(0, 0.0105/sqrt(AUM2+1e-12), 3)}
.param DWREL_MM={MM_ON*AGAUSS(0, 0.0075/sqrt(AUM2+1e-12), 3)}
.param DLREL_MM={MM_ON*AGAUSS(0, 0.0045000000000000005/sqrt(AUM2+1e-12), 3)}
.param WEFF={W*(1+DWREL_MM)}
.param LEFF={L*(1+DLREL_MM)}
M0 d g s b PMOS18_INT W={WEFF} L={LEFF} M={M} delvto={DVTH_MM}
.ends PMOS18

.subckt NMOS33 d g s b params: W=10u L=1u M=1
.param AUM2={(W/1u)*(L/1u)}
.param DVTH_MM={MM_ON*AGAUSS(0, 0.012/sqrt(AUM2+1e-12), 3)}
.param DWREL_MM={MM_ON*AGAUSS(0, 0.0075/sqrt(AUM2+1e-12), 3)}
.param DLREL_MM={MM_ON*AGAUSS(0, 0.0045000000000000005/sqrt(AUM2+1e-12), 3)}
.param WEFF={W*(1+DWREL_MM)}
.param LEFF={L*(1+DLREL_MM)}
M0 d g s b NMOS33_INT W={WEFF} L={LEFF} M={M} delvto={DVTH_MM}
.ends NMOS33


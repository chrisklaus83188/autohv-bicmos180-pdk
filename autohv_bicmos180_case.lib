.subckt NDMOS20 d g s params: W=10u M=1
* HV DMOS: width W is the size knob (m=W/W_REF); channel/drift length fixed at process min
.param W_REF=10u
.param mtot={(W/W_REF)*M}
.param DVTH_MM={MM_ON*AGAUSS(0, 0.024, 3)/sqrt(max(mtot,1e-6))}
.param Rth=200        ; K/W: thermal R, default for 20V class (override per-instance)
.param Cth=1e-06     ; J/K: thermal capacitance
Vshift g g_int DC {-DVTH_MM}
Rgmin  g g_int 1e9   ; gmin shunt: breaks the singular matrix when MM_ON=0 (DVTH_MM=0V) for cascoded LDMOS
.if (SH_ON==1)
* Self-heating ON (item #3): Vth shift + Pdiss-to-TJ thermal network.
B_thvth g_int g_th V={TC_VTO_NDMOS20*V(TJ)}
Vsense d d_sense DC 0
M0 d_sense g_th s NDMOS20_INT m={mtot}
B_pdiss 0 TJ I={V(d,s)*i(Vsense)}
Rth_n TJ 0 {Rth}
Cth_n TJ 0 {Cth} IC=0
.else
* Self-heating OFF (default): original M0 path, no thermal elements added.
M0 d g_int s NDMOS20_INT m={mtot}
.endif
.ends NDMOS20
.subckt PDMOS20 d g s params: W=10u M=1
* HV DMOS: width W is the size knob (m=W/W_REF); channel/drift length fixed at process min

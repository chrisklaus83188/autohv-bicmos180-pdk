.subckt RPOLY_HI p n params: L=100u W=10u
.param AUM2={(L/1u)*(W/1u)}
.param RMM={1+MM_ON*AGAUSS(0, 0.0045000000000000005/sqrt(AUM2+1e-12), 3)}
R0 p n RPOLY_HI_INT L={L*RMM} W={W}
.ends RPOLY_HI

